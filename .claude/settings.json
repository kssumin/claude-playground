{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == 'Bash' && tool_input.command matches '(bootRun|gradlew.*run)'",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] Long-running command - tmux 권장: tmux new-session -d -s dev'"
          }
        ],
        "description": "서버 실행 시 tmux 권장"
      },
      {
        "matcher": "tool == 'Bash' && tool_input.command matches 'docker-compose up$|docker compose up$'",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] 팁: 백그라운드 실행은 docker-compose up -d'"
          }
        ],
        "description": "docker-compose 백그라운드 실행 권장"
      },
      {
        "matcher": "tool == 'Bash' && tool_input.command matches 'git push'",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] main 브랜치 직접 push 금지. PR을 통해 진행하세요'"
          }
        ],
        "description": "git push 전 리뷰 알림"
      },
      {
        "matcher": "tool == 'Write' && tool_input.file_path matches '\\.(md|txt)$' && !(tool_input.file_path matches '(CLAUDE|\\.claude/|README|docs/plans/|docs/adr/|docs/solutions/|docs/troubleshooting/)')",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] 불필요한 문서 파일 생성 감지. 기존 docs/ 문서에 추가를 권장'"
          }
        ],
        "description": "불필요한 .md 파일 생성 경고"
      },
      {
        "matcher": "tool == 'Edit' || tool == 'Write'",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/suggest-compact.js\""
          }
        ],
        "description": "주기적으로 /compact 제안"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tool == 'Edit' || tool == 'Write'",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/loop-detect.js\""
          }
        ],
        "description": "동일 파일 반복 편집 감지 (5회 이상 경고)"
      },
      {
        "matcher": "(tool == 'Edit' || tool == 'Write') && tool_input.file_path matches '\\.kt$'",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/arch-domain-check.js\""
          }
        ],
        "description": "domain 모듈 .kt 편집 시 Spring infra 임포트 즉시 감지"
      },
      {
        "matcher": "tool == 'Edit' && tool_input.file_path matches '\\.kt$'",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/arch-unit-check.js\""
          }
        ],
        "description": "ArchUnit 백그라운드 실행 (.kt 편집 시 트리거)"
      },
      {
        "matcher": "tool == 'Edit' && tool_input.file_path matches '\\.kt$'",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/kotlin-compile-check.js\""
          }
        ],
        "description": "Kotlin 파일 편집 후 백그라운드 컴파일 체크"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/compile-result-check.js\""
          }
        ],
        "description": "백그라운드 컴파일 완료 시 즉시 결과 피드백"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/arch-unit-result-check.js\""
          }
        ],
        "description": "백그라운드 ArchUnit 완료 시 즉시 결과 피드백"
      },
      {
        "matcher": "(tool == 'Edit' || tool == 'Write') && tool_input.file_path matches 'Service\\.kt$'",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; SAVE_COUNT=$(grep -c '\\.save\\b\\|saveAll\\b\\|\\.delete\\b\\|deleteAll\\b' \"$FILE\" 2>/dev/null || echo 0); TX=$(grep -c '@Transactional' \"$FILE\" 2>/dev/null || echo 0); if [ \"$SAVE_COUNT\" -ge 2 ] && [ \"$TX\" -eq 0 ]; then echo '[Hook] Multi-save 감지: @Transactional 없음 → 원자성 보장 필요'; fi"
          }
        ],
        "description": "Service 다중 save 시 @Transactional 누락 감지"
      },
      {
        "matcher": "(tool == 'Edit' || tool == 'Write') && tool_input.file_path matches '(Outbox|OutboxEvent)\\.kt$'",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$ROOT/.claude/hooks/check-outbox-entity.sh\""
          }
        ],
        "description": "Outbox Entity 필수 필드 검증 (@Id, aggregateId, processed)"
      },
      {
        "matcher": "(tool == 'Edit' || tool == 'Write') && tool_input.file_path matches 'Consumer\\.kt$'",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$ROOT/.claude/hooks/check-consumer-idempotency.sh\""
          }
        ],
        "description": "Kafka Consumer 멱등성 체크 누락 감지"
      },
      {
        "matcher": "(tool == 'Edit' || tool == 'Write') && tool_input.file_path matches '\\.kt$'",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');const p=process.env.CLAUDE_TOOL_INPUT_FILE_PATH;if(p&&fs.existsSync(p)){const lines=fs.readFileSync(p,'utf8').split('\\n');const found=[];lines.forEach((l,i)=>{if(/\\bprintln\\b/.test(l)&&!/\\/\\//.test(l.split('println')[0]))found.push((i+1)+': '+l.trim())});if(found.length){console.error('[Hook] println 발견 - logger 사용 필요:');found.slice(0,3).forEach(m=>console.error(m))}}\""
          }
        ],
        "description": "println 감지 → logger 사용 권장"
      },
      {
        "matcher": "tool == 'Bash' && tool_input.command matches 'gh pr create'",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] PR 생성됨 - gh pr checks 로 CI 상태 확인하세요'"
          }
        ],
        "description": "PR 생성 후 CI 확인 안내"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/pre-compact.js\""
          }
        ],
        "description": "컨텍스트 압축 전 상태 저장"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/session-start.js\""
          }
        ],
        "description": "세션 시작 시 프로젝트 정보 로드"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/session-end.js\""
          }
        ],
        "description": "세션 종료 시 상태 저장"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/check-debug-logs.js\""
          }
        ],
        "description": "응답 후 디버그 로그 검사"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$ROOT/.claude/hooks/scripts/hooks/pre-completion-check.js\""
          }
        ],
        "description": "arch/compile 미검증 시 경고 + exec-plans 업데이트 리마인더"
      }
    ]
  }
}
